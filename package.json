{
	"name": "@aryrabelo/free-text-core",
	"version": "0.1.0",
	"description": "Runtime-agnostic core for free-text session notes: path scheme, persistence, markdown prompt-queue, line rendering, and a generic stats line. Shared by the Oh My Pi and Claude Code free-text plugins.",
	"type": "module",
	"license": "MIT",
	"author": "Ary Rabelo",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aryrabelo/free-text-core.git"
	},
	"homepage": "https://github.com/aryrabelo/free-text-core#readme",
	"bugs": {
		"url": "https://github.com/aryrabelo/free-text-core/issues"
	},
	"keywords": [
		"free-text",
		"notes",
		"scratchpad",
		"statusline",
		"prompt-queue",
		"session-notes",
		"ai-agent",
		"claude",
		"claude-code",
		"oh-my-pi",
		"omp",
		"markdown",
		"checkbox",
		"widget",
		"terminal"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"src",
		"!src/**/*.test.ts",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"engines": {
		"bun": ">=1.0.0"
	},
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/bun": "^1.3.0",
		"@types/node": "^22",
		"typescript": "^5.6.0"
	}
}
